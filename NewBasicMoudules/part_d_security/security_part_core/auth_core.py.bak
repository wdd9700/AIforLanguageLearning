class SensitiveOperation:

    """

    و•ڈو„ںو“چن½œç®،çگ†

    ه®‰ه…¨ç؛¢ç؛؟ï¼ڑو•ڈو„ںو“چن½œن؛Œو¬،ç،®è®?

    """

    

    # و•ڈو„ںو“چن½œç±»ه‍‹

    SENSITIVE_OPERATIONS = {

        "password_change": "ن؟®و”¹ه¯†ç پ",

        "email_change": "ن؟®و”¹é‚®ç®±",

        "account_delete": "و³¨é”€è´¦وˆ·",

        "api_key_regenerate": "é‡چو–°ç”ںوˆگAPIه¯†é’¥",

        "permission_grant": "وژˆن؛ˆو‌ƒé™گ",

    }

    

    # ه¾…ç،®è®¤çڑ„و•ڈو„ںو“چن½œï¼ˆç”ںن؛§çژ¯ه¢ƒه؛”ن½؟ç”¨ Redisï¼?

    _pending_confirmations: Dict[str, Dict[str, Any]] = {}

    

    @classmethod

    def require_confirmation(

        cls,

        user_id: str,

        operation_type: str,

        operation_data: Dict[str, Any],

        expires_minutes: int = 10

    ) -> str:

        """

        هˆ›ه»؛éœ€è¦پن؛Œو¬،ç،®è®¤çڑ„و•ڈو„ںو“چن½œ

        è؟”ه›‍ç،®è®¤ن»¤ç‰Œ

        """

        if operation_type not in cls.SENSITIVE_OPERATIONS:

            raise ValueError(f"وœھçں¥çڑ„و•ڈو„ںو“چن½œç±»ه‍?: {operation_type}")

        

        confirm_token = secrets.token_urlsafe(32)

        expire_at = datetime.now(timezone.utc) + timedelta(minutes=expires_minutes)

        

        cls._pending_confirmations[confirm_token] = {

            "user_id": user_id,

            "operation_type": operation_type,

            "operation_data": operation_data,

            "expire_at": expire_at,

            "confirmed": False

        }

        

        logger.info(f"هˆ›ه»؛و•ڈو„ںو“چن½œç،®è®¤: {operation_type} for user {user_id}")

        return confirm_token

    

    @classmethod

    def confirm_operation(cls, confirm_token: str, user_id: str) -> Optional[Dict[str, Any]]:

        """

        ç،®è®¤و•ڈو„ںو“چن½œ

        è؟”ه›‍و“چن½œو•°وچ®ï¼Œو— و•ˆهˆ™è؟”ه›‍ None

        """

        operation = cls._pending_confirmations.get(confirm_token)

        

        if not operation:

            logger.warning(f"و— و•ˆçڑ„ç،®è®¤ن»¤ç‰?: {confirm_token}")

            return None

        

        # éھŒè¯پç”¨وˆ·

        if operation["user_id"] != user_id:

            logger.warning(f"ç”¨وˆ·ن¸چهŒ¹é…?: {user_id} vs {operation['user_id']}")

            return None

        

        # و£€وں¥وک¯هگ¦è؟‡وœ?

        if datetime.now(timezone.utc) > operation["expire_at"]:

            del cls._pending_confirmations[confirm_token]

            logger.warning(f"ç،®è®¤ن»¤ç‰Œه·²è؟‡وœ?: {confirm_token}")

            return None

        

        # و ‡è®°ن¸؛ه·²ç،®è®¤

        operation["confirmed"] = True

        result = {

            "operation_type": operation["operation_type"],

            "operation_data": operation["operation_data"]

        }

        

        # و¸…çگ†

        del cls._pending_confirmations[confirm_token]

        

        logger.info(f"و•ڈو„ںو“چن½œه·²ç،®è®?: {operation['operation_type']} for user {user_id}")

        return result

    

    @classmethod

    def cancel_operation(cls, confirm_token: str, user_id: str) -> bool:

        """هڈ–و¶ˆه¾…ç،®è®¤çڑ„و•ڈو„ںو“چن½œ"""

        operation = cls._pending_confirmations.get(confirm_token)

        

        if operation and operation["user_id"] == user_id:

            del cls._pending_confirmations[confirm_token]

            logger.info(f"و•ڈو„ںو“چن½œه·²هڈ–و¶?: {confirm_token}")

            return True

        

        return False





