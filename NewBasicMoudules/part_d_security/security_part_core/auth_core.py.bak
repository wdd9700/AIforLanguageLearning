                token,

                JWTConfig.get_secret_key(),

                algorithms=[JWTConfig.ALGORITHM]

            )

            jti = payload.get("jti")

            if jti:

                cls._revoked_tokens.add(jti)

                logger.info(f"Tokenه·²و’¤é”€: {jti}")

                return True

        except JWTError:

            pass

        return False

    

    @classmethod

    def refresh_access_token(cls, refresh_token: str) -> Optional[str]:

        """ن½؟ç”¨هˆ·و–°ن»¤ç‰Œèژ·هڈ–و–°çڑ„è®؟é—®ن»¤ç‰Œ"""

        payload = cls.decode_token(refresh_token)

        

        if not payload:

            return None

        

        # ç،®ن؟‌وک¯هˆ·و–°ن»¤ç‰?

        if payload.get("type") != "refresh":

            logger.warning("ه°‌è¯•ن½؟ç”¨é‌‍هˆ·و–°ن»¤ç‰Œهˆ·و–?")

            return None

        

        user_id = payload.get("sub")

        if not user_id:

            return None

        

        return cls.create_access_token(user_id)





