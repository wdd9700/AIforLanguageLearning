{
  "name": "language-learning-server",
  "version": "1.0.0",
  "description": "AI-powered language learning server",
  "main": "dist/index.js",
  "author": "Your Team",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "check": "tsx ../scripts/check-cli-tools.ts",
    "check:old": "tsx ../scripts/check-services.ts",
    "test:quick": "tsx ../tests/test-quick.ts",
    "test:integration": "tsx ../tests/test-integration.ts",
    "test:ocr": "tsx ../tests/test-ocr.ts",
    "test:services": "tsx ../tests/test-services.ts",
    "test:endpoints": "tsx ../tests/test-endpoints.ts",
    "test": "npm run check && npm run test:services && npm run test:endpoints"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bonjour-service": "^1.2.10",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.1.0",
    "pino-pretty": "^10.2.3",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zeromq": "^6.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
